// frontend/tsconfig.json
{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@theme": ["src/theme/index.ts"],
      "@config": ["config/index.ts"],
      "@super-admin/*": ["src/super-admin/*"],
      "@utils/*": ["src/utils/*"]
    },
    "jsx": "react-native",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "app", // <- your Expo-Router pages
    "src",
    "config"
  ],
  "exclude": [
    "node_modules", // don’t ever try to parse deps’ tsconfigs
    "**/__tests__/*",
    "**/*.spec.ts"
  ]
}
