# ─── Node dependencies ───────────────────────────────
**/node_modules/
**/package-lock.json
**/yarn.lock

# ─── Expo / React Native caches & builds ────────────
.expo/
.expo-shared/
web-build/           # Expo web output
dist/                # any generic dist/ folders
build/               # if you add custom builds

# If you ever prebuild / eject:
android/
ios/

# ─── Environment and secrets ────────────────────────
# dotenv files (commit only .env.example if you have one)
*.env
*.env.local
*.env.*.local
!.env.example

# ─── Logs ────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS generated files ─────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor directories & settings ──────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Frontend runtime logs
frontend/src/utils/logs/

# Root logs
backend-dev.log
expo-web.log

# Python cache
__pycache__/
*.pyc

# E2E generated data
frontend/e2e/auth.json
frontend/e2e/auth_company.json
frontend/e2e/.playwright_profile/
frontend/e2e/reports/*.html
frontend/e2e/reports/*.xml
frontend/e2e/reports/previous_*.json
frontend/e2e/reports/previous_*.log

# Server logs
backend/server.log
frontend/server.log
backend/logs/

# Screenshots
frontend/screencap.png
