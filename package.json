{
  "name": "msuper-react-expo-app",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev --workspace backend\" \"npm:start --workspace frontend\"",
    "lint": "npm run lint -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "test": "npm run test -ws --if-present",
    "web": "npm run web --workspace frontend",
    "start:web": "npm run start:web --workspace frontend",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "expo-dev-client": "~5.2.4",
    "expo": "~53.0.24",
    "react": "19.0.0",
    "react-native": "0.79.6"
  },
  "version": "1.0.0"
}
