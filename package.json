{
  "name": "msuper-react-expo-app",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev --workspace backend\" \"npm:start --workspace frontend\"",
